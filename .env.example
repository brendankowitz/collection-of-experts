# ─────────────────────────────────────────────────────────────────────────────
# Expert Agents — Environment Variables
#
# Copy this file to .env and fill in your values.
# All variables are OPTIONAL — the system defaults to Mock providers and
# anonymous access when nothing is set.
#
# NEVER commit .env (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
# Password for the local Postgres container.
POSTGRES_PASSWORD=experts

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional password for the local Redis container.
# Leave blank (default) for no-auth development Redis.
REDIS_PASSWORD=

# Connection string AgentHost uses to reach Redis for the SignalR backplane.
# Default: redis:6379 (the service name inside docker-compose).
# For local dev outside Docker: localhost:6379
REDIS_CONNECTION_STRING=redis:6379

# ── LLM providers (all optional — defaults to Mock) ──────────────────────────
# Which provider to use by default: Mock | OpenAI | AzureOpenAI | Anthropic | Ollama
LLM_DEFAULT_PROVIDER=Mock

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# Deployment name for the chat model (default: gpt-4o)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# Deployment name for the embedding model (default: text-embedding-3-large)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

OPENAI_API_KEY=

ANTHROPIC_API_KEY=

# ── Entra ID authentication ───────────────────────────────────────────────────
# Set AUTH_MODE=EntraId to enable Entra ID JWT validation.
# Default: Disabled (all endpoints are anonymous).
AUTH_MODE=Disabled

ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# The API audience URI (e.g. api://<client-id>)
ENTRA_AUDIENCE=

# ── Web Chat ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach AgentHost.
# Override when agenthost is behind a reverse proxy or on a different host.
VITE_API_URL=http://localhost:5000

# ── Application Insights (optional) ──────────────────────────────────────────
# Set to enable Azure Monitor / Application Insights telemetry.
APPINSIGHTS_CONNECTION_STRING=

# ── GitHub source adapter (optional) ─────────────────────────────────────────
GITHUB_PAT=

# ── Azure DevOps source adapter (optional) ────────────────────────────────────
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG=
