{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Llm": {
    "DefaultProvider": "Mock",
    "DefaultModel": "gpt-4o",
    "Providers": {
      "OpenAI": {
        "ApiKey": ""
      },
      "AzureOpenAI": {
        "Endpoint": "",
        "ApiKey": "",
        "Deployments": {
          "chat": "gpt-4o"
        }
      },
      "Anthropic": {
        "ApiKey": ""
      },
      "Ollama": {
        "Endpoint": "http://localhost:11434"
      }
    },
    "AgentOverrides": {
      "fhir-server-expert": {
        "Provider": "Mock",
        "Model": "gpt-4o"
      },
      "healthcare-components-expert": {
        "Provider": "Mock",
        "Model": "gpt-4o"
      }
    }
  },
  "Persistence": {
    "TaskStore": { "Backend": "InMemory" },
    "Memory": {
      "Backend": "InMemory",
      "Postgres": { "ConnectionString": null },
      "Qdrant": { "Collection": "agent_memory" },
      "DefaultRetentionDays": 30,
      "SummaryModelOverride": null,
      "SweepIntervalMinutes": 60
    }
  },
  "Indexing": {
    "UseRealRetriever": false,
    "RepoCacheDir": "./repo-cache",
    "MaxFileSizeBytes": 1048576,
    "Qdrant": {
      "Host": "localhost",
      "GrpcPort": 6334,
      "ApiKey": ""
    },
    "Postgres": {
      "ConnectionString": "Host=localhost;Database=experts;Username=experts;Password=experts"
    },
    "Embedder": {
      "Provider": "Mock",
      "Model": "",
      "ApiKey": ""
    }
  },
  "Orchestration": {
    "EnableCoordinator": true,
    "DefaultRoutingMode": "coordinator",
    "Coordinator": {
      "MaxParallelAgents": 4,
      "EnableSynthesis": true,
      "SynthesisModelOverride": null
    },
    "MaxCallDepth": 5,
    "InProcessCallsForLocalAgents": true
  },
  "Repositories": {
    "Backend": "InMemory",
    "ConnectionString": "Host=localhost;Database=experts;Username=experts;Password=experts",
    "Sources": {
      "GitHub": {
        "AuthMode": "Pat",
        "Pat": ""
      },
      "AzureDevOps": {
        "Pat": "",
        "Organization": ""
      }
    },
    "Seed": [
      {
        "Source": "github",
        "OwnerOrOrg": "microsoft",
        "Name": "fhir-server",
        "AgentPersona": "FHIR Server Expert",
        "Enabled": true
      },
      {
        "Source": "github",
        "OwnerOrOrg": "microsoft",
        "Name": "healthcare-shared-components",
        "AgentPersona": "Healthcare Shared Components Expert",
        "Enabled": true
      }
    ]
  },
  "Authentication": {
    "Mode": "Disabled",
    "EntraId": {
      "Instance": "https://login.microsoftonline.com/",
      "TenantId": "",
      "ClientId": "",
      "Audience": ""
    }
  },
  "SignalR": {
    "Redis": {
      "ConnectionString": ""
    }
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Observability": {
    "Otel": {
      "Enabled": true,
      "ServiceName": "agenthost",
      "Exporter": "Otlp",
      "OtlpEndpoint": null,
      "ConsoleExporter": false
    },
    "ApplicationInsights": { "ConnectionString": null }
  }
}